# MSAL configuration for local development

# SPA App Registration (public client, redirect flow)
VITE_MSAL_CLIENT_ID=fc533647-d055-49c7-8b8b-553d4b9df6eb
VITE_MSAL_TENANT_ID=ucatalyst.onmicrosoft.com
VITE_MSAL_REDIRECT_URI=http://localhost:5173

# Web API App Registration (audience for access tokens issued to the SPA).
# Change the scope suffix if you named it something other than access_as_user.
VITE_API_CLIENT_ID=8e183c78-0db1-4cd8-bb04-25ccbcb0730d
VITE_API_SCOPE=api://8e183c78-0db1-4cd8-bb04-25ccbcb0730d/access_as_user
VITE_API_BASE_URL=http://localhost:5100/api/v1
